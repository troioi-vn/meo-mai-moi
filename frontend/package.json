{
  "name": "frontend",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && bun run blade:update && bun run assets:copy",
    "build:analyze": "ANALYZE=true vp build",
    "build:docker": "vp build && bun run blade:update && bun run assets:copy",
    "assets:copy": "node ./scripts/copy-assets.cjs",
    "blade:update": "node ./scripts/update-blade.cjs",
    "lint": "vp lint .",
    "lint:deps": "depcruise src --config .dependency-cruiser.cjs",
    "lint:dead": "ts-prune --project tsconfig.app.json",
    "test": "vp test run",
    "test:silent": "vp test run --reporter=dot --silent",
    "test:minimal": "vp test run --reporter=dot --silent --no-coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test:backend": "cd ../backend && php artisan test --parallel",
    "e2e": "./scripts/e2e-test.sh",
    "e2e:direct": "playwright test",
    "e2e:ui": "SKIP_E2E_SETUP=true playwright test --ui",
    "e2e:report": "playwright show-report",
    "test:e2e": "./scripts/e2e-test.sh",
    "preview": "vp preview",
    "format": "vp fmt .",
    "api:generate": "orval",
    "api:watch": "orval --watch",
    "api:check": "orval && git diff --exit-code src/api/generated",
    "i18n:scan": "echo 'WARNING: i18next-scanner cannot parse modern TypeScript syntax. Use i18n:check for analysis instead.' && i18next-scanner --config i18next-scanner.config.cjs || true",
    "i18n:unused": "i18n-check --locales src/i18n/locales --source en --format i18next --only unused --unused src --reporter summary",
    "i18n:missing": "i18n-check --locales src/i18n/locales --source en --format i18next --only missingKeys --reporter summary",
    "i18n:check": "i18n-check --locales src/i18n/locales --source en --format i18next --reporter summary",
    "i18n:ci": "i18n-check --locales src/i18n/locales --source en --format i18next --only missingKeys,invalidKeys --reporter summary",
    "i18n:clean": "echo 'Use i18n:unused to identify unused keys, then manually remove them for safety'",
    "i18n:clean-placeholders": "node scripts/clean-translation-placeholders.cjs"
  },
