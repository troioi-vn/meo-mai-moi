{
  "openapi": "3.0.0",
  "info": {
    "title": "Meo Mai Moi API",
    "description": "API for Meo Mai Moi, a cat care management platform.",
    "contact": {
      "email": "support@meomaimoi.com"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Development server"
    }
  ],
  "paths": {
    "/api/gpt-auth/confirm": {
      "post": {
        "tags": [
          "GPT Auth"
        ],
        "summary": "Confirm GPT connector consent",
        "description": "Validates GPT session signature for an authenticated user and generates a one-time auth code redirect URL for the connector callback.",
        "operationId": "8b274f88717c7022abb0ce2a47361124",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "session_id",
                  "session_sig"
                ],
                "properties": {
                  "session_id": {
                    "type": "string",
                    "format": "uuid",
                    "example": "7e8e7807-778f-489f-9407-bf64af1c8fff"
                  },
                  "session_sig": {
                    "type": "string",
                    "example": "f4a8d23236d5a0f8f8fcb86c7dbe34ad67d6c9f1a0f00114bca2fd249299f2d0"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Consent confirmed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "properties": {
                        "redirect_url": {
                          "type": "string",
                          "format": "uri",
                          "example": "https://gpt.troioi.vn/oauth/callback?session_id=7e8e7807-778f-489f-9407-bf64af1c8fff&code=66e5f8e5-8fa6-4b4a-85cb-b45f7f878f1a"
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Invalid signature or replayed session",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Invalid session signature."
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "description": "GPT connector is not configured",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "GPT connector is not configured."
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated"
          }
        },
        "security": [
          {
            "sanctum": []
          }
        ]
      }
    },
    "/api/gpt-auth/exchange": {
      "post": {
        "tags": [
          "GPT Auth"
        ],
        "summary": "Exchange GPT auth code",
        "description": "Server-to-server endpoint used by the GPT connector to exchange a one-time auth code for a Sanctum token and user id.",
        "operationId": "b5a8347eefd9652bcdbf153f351f077d",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer connector API key. Format: Bearer {GPT_CONNECTOR_API_KEY}",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "code"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "format": "uuid",
                    "example": "66e5f8e5-8fa6-4b4a-85cb-b45f7f878f1a"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Code exchanged successfully",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "properties": {
                        "sanctum_token": {
                          "type": "string",
                          "example": "1|qSZv6A7XQ9Q..."
                        },
                        "user_id": {
                          "type": "integer",
                          "example": 42
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired code",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Invalid or expired code."
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized connector API key"
          }
        }
      }
    },
    "/api/gpt-auth/register": {
      "post": {
        "tags": [
          "GPT Auth"
        ],
        "summary": "Register user for GPT connector flow",
        "description": "Registers a new user without invitation code during a valid GPT OAuth session and logs the user into the web session.",
        "operationId": "3262d9385db0c5ea0cadca2d70ef7a88",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "session_id",
                  "session_sig",
                  "name",
                  "email",
                  "password",
                  "password_confirmation"
                ],
                "properties": {
                  "session_id": {
                    "type": "string",
                    "format": "uuid",
                    "example": "7e8e7807-778f-489f-9407-bf64af1c8fff"
                  },
                  "session_sig": {
                    "type": "string",
                    "example": "f4a8d23236d5a0f8f8fcb86c7dbe34ad67d6c9f1a0f00114bca2fd249299f2d0"
                  },
                  "name": {
                    "type": "string",
                    "example": "GPT User"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "gpt-user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "Password1secure"
                  },
                  "password_confirmation": {
                    "type": "string",
                    "format": "password",
                    "example": "Password1secure"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered and logged in",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "properties": {
                        "user": {
                          "properties": {
                            "id": {
                              "type": "integer",
                              "example": 42
                            },
                            "name": {
                              "type": "string",
                              "example": "GPT User"
                            },
                            "email": {
                              "type": "string",
                              "format": "email",
                              "example": "gpt-user@example.com"
                            }
                          },
                          "type": "object"
                        },
                        "requires_verification": {
                          "type": "boolean",
                          "example": true
                        },
                        "email_verified": {
                          "type": "boolean",
                          "example": false
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Invalid signature or replayed session",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Invalid session signature."
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/gpt-auth/revoke": {
      "post": {
        "tags": [
          "GPT Auth"
        ],
        "summary": "Revoke GPT-issued Sanctum token",
        "description": "Server-to-server endpoint used by the GPT connector to revoke a plaintext Sanctum token. This endpoint is idempotent.",
        "operationId": "120006edd9e893abcbef920ed8d61451",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer connector API key. Format: Bearer {GPT_CONNECTOR_API_KEY}",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string",
                    "example": "1|qSZv6A7XQ9Q..."
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token revoked (or already absent)",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "properties": {
                        "revoked": {
                          "type": "boolean",
                          "example": true
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized connector API key"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sanctum": {
        "type": "apiKey",
        "description": "Use format: Bearer {token}",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "tags": [
    {
      "name": "GPT Auth",
      "description": "GPT Auth"
    }
  ]
}
