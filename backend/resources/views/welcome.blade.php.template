<!DOCTYPE html>
<html lang="{{ str_replace('_', '-', app()->getLocale()) }}">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
        <meta name="mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="default">
        <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('icon-32.png') }}">
        <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('icon-16.png') }}">
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}">
        <link rel="manifest" id="app-manifest" href="{{ asset('site-light.webmanifest') }}?v={{ config('version.api') }}">
        <meta name="theme-color" content="#ffffff">
        <meta name="color-scheme" content="light">
        <script>
            ;(function () {
                const root = document.documentElement
                const manifestEl = document.getElementById('app-manifest')
                const themeColorMeta = document.querySelector('meta[name="theme-color"]')
                const colorSchemeMeta = document.querySelector('meta[name="color-scheme"]')
                const mq = matchMedia('(prefers-color-scheme: dark)')

                function getResolvedTheme() {
                    const storedTheme = localStorage.getItem('vite-ui-theme')

                    if (storedTheme === 'dark') {
                        return { theme: 'dark', resolvedTheme: 'dark' }
                    }

                    if (storedTheme === 'light') {
                        return { theme: 'light', resolvedTheme: 'light' }
                    }

                    return {
                        theme: 'system',
                        resolvedTheme: mq.matches ? 'dark' : 'light',
                    }
                }

                function applyBodyTheme(resolvedTheme) {
                    if (!document.body) {
                        return
                    }

                    document.body.dataset.theme = resolvedTheme
                    document.body.style.colorScheme = resolvedTheme
                }

                function applyTheme() {
                    const { theme, resolvedTheme } = getResolvedTheme()

                    root.classList.remove('light', 'dark')
                    root.classList.add(resolvedTheme)
                    root.dataset.theme = resolvedTheme
                    root.dataset.themePreference = theme
                    root.style.colorScheme = resolvedTheme

                    manifestEl.href =
                        "{{ asset('') }}" + (resolvedTheme === 'dark' ? 'site-dark.webmanifest' : 'site-light.webmanifest') + "?v={{ config('version.api') }}"

                    if (themeColorMeta) {
                        themeColorMeta.setAttribute('content', resolvedTheme === 'dark' ? '#020817' : '#ffffff')
                    }

                    if (colorSchemeMeta) {
                        colorSchemeMeta.setAttribute('content', resolvedTheme)
                    }

                    applyBodyTheme(resolvedTheme)
                }

                mq.addEventListener('change', applyTheme)
                window.addEventListener('storage', applyTheme)
                document.addEventListener('DOMContentLoaded', function () {
                    applyBodyTheme(root.dataset.theme || 'light')
                }, { once: true })
                applyTheme()
                window.__updateManifest = applyTheme
            })()
        </script>

        <title>Meo Mai Moi</title>

        <!-- Built assets from frontend build process -->
        <link rel="stylesheet" href="{{ asset('build/assets/index-B0Rq5luw.css') }}">
        <script type="module" src="{{ asset('build/assets/index-mKHsPWRa.js') }}"></script>
    </head>
    <body class="bg-background text-foreground">
        <div id="root"></div>
    </body>
</html>
