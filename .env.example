# ==============================================================================
# Docker Compose Environment Variables
# ==============================================================================
# This file contains variables used by docker-compose.yml for:
#   - Build-time arguments (passed to Dockerfile)
#   - Container networking
#   - Volume management
#
# Copy this file to `.env` and fill in your values.
# The `.env` file is gitignored and should be kept separate per environment.
#
# For Laravel runtime configuration, see backend/.env
# ==============================================================================

# --- Web Push (VAPID) Configuration ---
# These keys are required for browser push notifications.
# Generate with: bun x web-push generate-vapid-keys
#
# VAPID_PUBLIC_KEY is passed as a build arg to the Docker image so that
# the frontend build can embed it in the JavaScript bundle.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Reverb (WebSockets) Configuration ---
# These are passed as build args to the frontend build.
# Defaults for local development:
VITE_REVERB_APP_KEY=mgyigyotlxz3rse8xcu4
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# --- Umami Analytics ---
# Optional: privacy-friendly analytics for the frontend SPA.
# These values are passed as build args so Vite can embed them in the frontend bundle.
# Leave blank to disable Umami.
VITE_UMAMI_URL=https://umami.example.com
VITE_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000
# Optional comma-separated allowlist, e.g. example.com,www.example.com
VITE_UMAMI_DOMAINS=
# Optional flags. Defaults are false in the wrapper/package.
VITE_UMAMI_DEBUG=false
VITE_UMAMI_LAZY_LOAD=false

# --- Telegram Notifications ---
# Optional: Configure Telegram bot for deployment and monitoring alerts
# Leave DEPLOY_NOTIFY_ENABLED=false to disable
# Get bot token from @BotFather, get chat ID from @userinfobot
DEPLOY_NOTIFY_ENABLED=false
TELEGRAM_BOT_TOKEN=
CHAT_ID=

# --- Docker Compose Settings ---
# Uncomment to override default project name (defaults to directory name)
# COMPOSE_PROJECT_NAME=meo-mai-moi

# --- Database Configuration ---
# These are used by the db service in docker-compose.yml
# Make sure these match the values in backend/.env
POSTGRES_DB=meo_mai_moi
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# --- Host Port Mappings ---
# Customize host-side port bindings when this stack shares a server with other services.
# Defaults preserve the current local-dev behavior.
#
# Example for catarchy2 behind host NGINX:
# BACKEND_HOST_BIND=127.0.0.1
# BACKEND_HOST_PORT=8001
# REVERB_HOST_BIND=127.0.0.1
# REVERB_HOST_PORT=8081
# DB_HOST_BIND=127.0.0.1
# DB_HOST_PORT=5433
#
# Optional HTTPS proxy ports for local development when ENABLE_HTTPS=true:
# HTTPS_HTTP_HOST_BIND=0.0.0.0
# HTTPS_HTTP_HOST_PORT=80
# HTTPS_HTTPS_HOST_BIND=0.0.0.0
# HTTPS_HTTPS_HOST_PORT=443
#
# Default HTTP app port used by the backend service
# BACKEND_HOST_BIND=0.0.0.0
# BACKEND_HOST_PORT=8000
#
# Default WebSocket/Reverb port exposed from the backend container
# REVERB_HOST_BIND=0.0.0.0
# REVERB_HOST_PORT=8080
#
# Default PostgreSQL port exposed from the db container
# DB_HOST_BIND=0.0.0.0
# DB_HOST_PORT=5432
