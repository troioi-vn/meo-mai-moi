{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "laravel/laravel",
  "type": "project",
  "description": "The skeleton application for the Laravel framework.",
  "keywords": [
    "laravel",
    "framework"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "ext-bcmath": "*",
    "ext-curl": "*",
    "ext-gd": "*",
    "ext-intl": "*",
    "ext-mbstring": "*",
    "ext-xml": "*",
    "ext-zip": "*",
    "bezhansalleh/filament-shield": "^4.1",
    "darkaonline/l5-swagger": "^11.0",
    "fakerphp/faker": "^1.24",
    "filament/filament": "^5.2",
    "giggsey/libphonenumber-for-php": "^9.0",
    "intervention/image": "^4.0",
    "lara-zeus/spatie-translatable": "^2.0",
    "laravel-notification-channels/telegram": "^7.0",
    "laravel/framework": "^13",
    "laravel/jetstream": "^5.3",
    "laravel/reverb": "^1.0",
    "laravel/sanctum": "^4.0",
    "laravel/socialite": "^5.24",
    "laravel/tinker": "^3.0",
    "minishlink/web-push": "^10.0",
    "spatie/laravel-medialibrary": "^11",
    "spatie/laravel-translatable": "^6.12",
    "stechstudio/filament-impersonate": "^5.0",
    "symfony/http-client": "^8.0",
    "symfony/mailgun-mailer": "^8.0",
    "tomatophp/filament-users": "^5.0"
  },
  "require-dev": {
    "brianium/paratest": "^7.22",
    "deptrac/deptrac": "^4.6",
    "friendsofphp/php-cs-fixer": "^3.82",
    "larastan/larastan": "^3.0",
    "laravel/pail": "^1.2.2",
    "laravel/pint": "^1.13",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.6",
    "phpunit/phpunit": "^13.1"
  },
  "autoload": {
    "files": [
      "app/helpers.php"
    ],
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi",
      "@php artisan filament:upgrade"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php artisan migrate --graceful --ansi"
    ],
    "test": [
      "@php artisan config:clear --ansi",
      "@php artisan test --parallel --processes=4"
    ],
    "format": [
      "./vendor/bin/php-cs-fixer fix"
    ],
    "phpstan": [
      "./vendor/bin/phpstan analyse --memory-limit=2G"
    ],
    "phpstan:baseline": [
      "./vendor/bin/phpstan analyse --generate-baseline --memory-limit=2G"
    ],
    "deptrac": [
      "./vendor/bin/deptrac analyse"
    ],
    "deptrac:baseline": [
      "./vendor/bin/deptrac analyse --report-uncovered --formatter=baseline"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
